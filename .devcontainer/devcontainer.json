// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-in-docker
{
	"name": "calendar-subscriptoin-hub",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:bullseye",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:3": {
			"version": "latest",
			"enableNonRootDocker": "true",
			"moby": "true"
		},
		"ghcr.io/devcontainers/features/node:2": {}
	},
	"forwardPorts": [
		3000,
		3001,
		5432,
		6379
	],
	"containerEnv": {
		"DEVCONTAINER": "true",
		"DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/calendar_subscription_hub?schema=public",
		"DIRECT_DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/calendar_subscription_hub?schema=public",
		"REDIS_URL": "redis://localhost:6379",
		"APP_BASE_URL": "http://localhost:3000",
		"ASISMETRO_API_BASE_URL": "http://localhost:3001"
	},
	"postCreateCommand": "npm run devcontainer:bootstrap",
	"postStartCommand": "npm run devcontainer:poststart",
	"customizations": {
		"vscode": {
			"extensions": [
				"ismola.ismola-extension-pack"
			]
		}
	}
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "docker --version",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}